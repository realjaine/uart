>>> Actively Locating Library Models...
@file(run_modus_atpg_uart.tcl) 19: set LIBRARY ""
@file(run_modus_atpg_uart.tcl) 20: catch {
    set raw_files [exec bash -c "find /home/install/FOUNDRY/digital/90nm/dig/ -type f | grep -E \"\\.v$|\\.v\\.gz$|\\.V$\""]
    set LIBRARY [split $raw_files "\n"]
}
@file(run_modus_atpg_uart.tcl) 26: set TESTMODE FULLSCAN
@file(run_modus_atpg_uart.tcl) 29: set ASSIGNFILE ""
@file(run_modus_atpg_uart.tcl) 30: set MODEDEF ""
@file(run_modus_atpg_uart.tcl) 31: catch {
    set ASSIGNFILE [exec bash -c "find $WORKDIR -type f -name \"*.pinassign\" | head -n 1"]
    set MODEDEF    [exec bash -c "find $WORKDIR -type f -name \"*.modedef\"   | head -n 1"]
}
@file(run_modus_atpg_uart.tcl) 37: set do_build_model 1;
@file(run_modus_atpg_uart.tcl) 38: set do_fault_model 1;
