@file(run_modus_atpg_uart.tcl) 49: if {$do_build_model} {
    puts "Building Test Model for $CELL"
    build_model  \
       -cell            $CELL        \
       -workdir         $WORKDIR     \
       -designsource    $NETLIST     \
       -TECHLIB         $LIBRARY     \
       -allowmissingmodules yes
}
