@file(run_modus_atpg_uart.tcl) 62: if {$do_build_testmode_FULLSCAN} {
    puts "Building Test Mode $TESTMODE"
    if {$MODEDEF ne ""} {
        build_testmode \
           -workdir   $WORKDIR     \
           -testmode  $TESTMODE    \
           -modedef   $MODEDEF     \
           -assignfile $ASSIGNFILE
    } else {
        build_testmode \
           -workdir    $WORKDIR    \
           -testmode   $TESTMODE   \
           -assignfile $ASSIGNFILE
    }
}
