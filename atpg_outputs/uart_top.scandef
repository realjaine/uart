       u_tx_sample_cnt_reg[2] ( IN SI ) ( OUT Q ) 
       u_tx_sample_cnt_reg[3] ( IN SI ) ( OUT Q ) 
       u_tx_shift_reg_reg[0] ( IN SI ) ( OUT Q ) 
       u_tx_shift_reg_reg[1] ( IN SI ) ( OUT Q ) 
