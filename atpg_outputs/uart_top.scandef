       u_rx_shift_reg_reg[7] ( IN SI ) ( OUT Q ) 
       u_rx_state_reg[0] ( IN SI ) ( OUT Q ) 
       u_rx_state_reg[1] ( IN SI ) ( OUT Q ) 
       u_tx_baud_cnt_reg[0] ( IN SI ) ( OUT Q ) 
